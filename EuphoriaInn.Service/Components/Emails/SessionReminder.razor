@using EuphoriaInn.Service.Components.Emails

<_EmailLayout Subject="@($"Reminder: {QuestTitle} is tomorrow")" PreviewText="@($"Session Tomorrow — {QuestTitle} on {QuestDate:dddd, MMMM d}")">
    <table width="600" cellpadding="0" cellspacing="0" border="0" style="background-image:url('@(AppUrl)/images/Blanks/Blanks%20w%20Shadow/Poster1.png');background-size:cover;background-position:center top;background-color:#F4E4BC;margin:0 auto;">
        <tr>
            <td height="840" style="min-height:840px;">
                <table width="100%" border="0" cellpadding="0" cellspacing="0">

                    <!-- Row 1: CR Badge -->
                    <tr>
                        <td style="padding:5% 0 0 8%;vertical-align:top;text-align:left;">
                            <table border="0" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="background:linear-gradient(135deg,#8B4513,#A0522D);color:#FFD700;font-weight:bold;font-size:18px;padding:8px 14px;border-radius:8px;border:2px solid #FFD700;box-shadow:0 4px 8px rgba(0,0,0,0.3);text-shadow:1px 1px 2px rgba(0,0,0,0.7);display:inline-block;transform:rotate(-5deg);">⬡ CR @ChallengeRating</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 2: Quest Title -->
                    <tr>
                        <td style="padding:8px 16px 8px 16px;text-align:center;">
                            <table width="100%" border="0" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size:38px;font-weight:700;font-family:'Cinzel',serif;color:#1a0f08;line-height:1.2;text-align:center;word-break:break-word;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">Your Quest Awaits Tomorrow</td>
                                </tr>
                                <tr>
                                    <td style="font-size:26px;font-weight:700;font-family:'Cinzel',serif;color:#1a0f08;text-align:center;padding-top:8px;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@QuestTitle</td>
                                </tr>
                                <tr>
                                    <td style="font-size:15px;font-family:Georgia,serif;color:#1a0f08;text-align:center;padding-top:4px;font-style:italic;text-shadow:2px 2px 4px rgba(255,255,255,0.9);">Be ready, adventurer. Your session is confirmed for tomorrow.</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 3: Description Section -->
                    <tr>
                        <td style="padding:16px 88px 8px 88px;text-align:left;">
                            <table width="100%" border="0" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);padding-bottom:4px;">The Adventure:</td>
                                </tr>
                                <tr>
                                    <td style="font-size:15px;font-family:Georgia,serif;color:#1a0f08;line-height:1.6;font-style:italic;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@QuestDescription</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 4: Gold Divider -->
                    <tr>
                        <td style="padding:0 16px;"><hr style="border:none;border-top:1px solid #FFD700;margin:0;" /></td>
                    </tr>

                    <!-- Row 5: Metadata Labels -->
                    <tr>
                        <td style="padding:8px 88px;">
                            <table width="100%" border="0" cellpadding="4" cellspacing="0">
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">Dungeon Master:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@DmName</td>
                                </tr>
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">Session Date:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@QuestDate.ToString("dddd, MMMM d")</td>
                                </tr>
                                <tr>
                                    <td style="font-size:14px;font-weight:700;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);" valign="top">Fellow Adventurers:</td>
                                    <td style="font-size:14px;font-family:Georgia,serif;color:#1a0f08;text-shadow:2px 2px 4px rgba(255,255,255,0.9),1px 1px 6px rgba(0,0,0,0.5);">@string.Join(", ", ConfirmedPlayerNames)</td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- Row 6: CTA Button -->
                    <tr>
                        <td style="padding:24px 16px;text-align:center;">
                            <a href="@QuestUrl" style="background-color:#FFD700;color:#1a0f08;font-family:'Cinzel',serif;font-size:15px;font-weight:bold;padding:12px 24px;border-radius:6px;text-decoration:none;display:inline-block;border:2px solid #8B4513;text-align:center;">View Quest Details</a>
                        </td>
                    </tr>

                    <!-- Row 7: Wax Seal -->
                    <tr>
                        <td style="padding:64px 16px 24px 16px;text-align:left;">
                            <img src="@(AppUrl)/images/Wax%20Seals/Crown%20Seal.png" width="80" alt="Wax Seal" style="display:block;" />
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</_EmailLayout>

@code {
    [Parameter, EditorRequired] public string QuestTitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string DmName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public DateTime QuestDate { get; set; }
    [Parameter, EditorRequired] public string QuestDescription { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IList<string> ConfirmedPlayerNames { get; set; } = [];
    [Parameter, EditorRequired] public string QuestUrl { get; set; } = string.Empty;
    [Parameter, EditorRequired] public int ChallengeRating { get; set; }
    [Parameter, EditorRequired] public string AppUrl { get; set; } = string.Empty;
}
